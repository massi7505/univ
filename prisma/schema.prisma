generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role     @default(STUDENT)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  otpCode      String?
  otpExpiresAt DateTime?

  viewHistory ProductView[]
  loans       ProductLoan[]
}

enum Role {
  ADMIN
  STUDENT
}

model Building {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  rooms     Room[]
}

model Room {
  id         String   @id @default(cuid())
  name       String
  buildingId String
  building   Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  cabinets   Cabinet[]

  @@unique([name, buildingId])
}

enum CabinetType {
  CABINET
  FRIDGE
  FREEZER
}

model Cabinet {
  id        String      @id @default(cuid())
  name      String
  type      CabinetType @default(CABINET)
  roomId    String
  room      Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  shelves   Shelf[]

  @@unique([name, roomId])
}

model Shelf {
  id        String    @id @default(cuid())
  name      String
  cabinetId String
  cabinet   Cabinet   @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  products  Product[]

  @@unique([name, cabinetId])
}

model Product {
  id              String   @id @default(cuid())
  cas             String?
  name            String
  molarMass       Float?
  stock           String?
  packagingValue  Float?
  packagingUnit   String?
  brand           String?
  toxic           Boolean  @default(false)
  cmr             Boolean  @default(false)
  explosive       Boolean  @default(false)
  flammable       Boolean  @default(false)
  oxidizing       Boolean  @default(false)
  gasPressure     Boolean  @default(false)
  corrosive       Boolean  @default(false)
  harmfulIrritant Boolean  @default(false)
  healthHazard    Boolean  @default(false)
  envHazard       Boolean  @default(false)
  purityPercent   Float?
  physicalState   String?
  comment         String?  @db.Text
  globalStockType String?
  active          Boolean  @default(true)
  shelfId         String
  shelf           Shelf    @relation(fields: [shelfId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  viewHistory ProductView[]
  loans       ProductLoan[]
}

model ProductView {
  id        String   @id @default(cuid())
  userId    String
  productId String
  viewedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductLoan {
  id         String    @id @default(cuid())
  userId     String
  productId  String
  takenAt    DateTime  @default(now())
  returnedAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AppConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}
